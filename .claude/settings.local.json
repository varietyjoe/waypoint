{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(node database/init.js:*)",
      "Bash(node test-database.js:*)",
      "Bash(npm start)",
      "Bash(node test-api.js:*)",
      "Bash(ls:*)",
      "Bash(curl:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(node -e:*)",
      "Bash(npm uninstall:*)",
      "Bash(env)",
      "Bash(node -c:*)",
      "Bash(jq:*)",
      "Bash(lsof:*)",
      "Bash(xargs lsof:*)",
      "Bash(python3:*)",
      "Bash(ngrok http:*)",
      "Bash(sqlite3:*)",
      "Bash(node:*)",
      "Bash(open http://localhost:3000)",
      "Bash(pgrep:*)",
      "Bash(xargs cat:*)",
      "Bash(open:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(ipconfig getifaddr:*)",
      "Bash(cat:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(date:*)",
      "Bash(chmod:*)"
    ]
  }
}
