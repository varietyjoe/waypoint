# Waypoint Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Server
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# Mobile API key — used to authenticate requests from the PWA
WAYPOINT_API_KEY=

# CORS — the Vercel URL of your waypoint-mobile frontend
ALLOWED_ORIGIN=https://your-app.vercel.app

# Database path (leave blank for local default: database/waypoint.db)
# Docker/Railway default: /app/database/waypoint.db
DATABASE_PATH=

# Anthropic
ANTHROPIC_API_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Grain
GRAIN_CLIENT_ID=
GRAIN_CLIENT_SECRET=

# Railway CI/CD webhook (stored as GitHub Actions secret)
# RAILWAY_WEBHOOK_URL=
